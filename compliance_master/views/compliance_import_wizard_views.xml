<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_compliance_import_wizard_form" model="ir.ui.view">
        <field name="name">compliance.import.wizard.form</field>
        <field name="model">compliance.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Compliance Records from Excel">

                <!-- ── STEP 1: UPLOAD ──────────────────────────────────── -->
                <group attrs="{'invisible': [('state', '!=', 'upload')]}">
                    <group string="Step 1 – Upload Excel File">
                        <field name="excel_file" filename="excel_filename" widget="binary"
                               string="Select .xlsx File"/>
                        <field name="excel_filename" invisible="1"/>
                        <field name="sheet_name" string="Sheet to Import"/>
                    </group>
                    <group string="Import Options">
                        <field name="skip_existing"/>
                        <field name="clear_existing"/>
                    </group>

                    <div style="background:#fff8e1;border-left:4px solid #f39c12;
                                padding:10px 14px;margin:10px 0;border-radius:4px;">
                        <strong>Instructions:</strong>
                        <ol style="margin:6px 0 0 16px;font-size:12px;">
                            <li>Upload your <strong>Compliance Master.xlsx</strong> file.</li>
                            <li>Select the sheet — use <em>MASTER (2)</em> for the full list.</li>
                            <li>Click <strong>Analyse</strong> to preview what will be imported.</li>
                            <li>Review the preview, then click <strong>Import Now</strong>.</li>
                        </ol>
                    </div>
                </group>

                <!-- ── STEP 2: PREVIEW ─────────────────────────────────── -->
                <group attrs="{'invisible': [('state', '!=', 'preview')]}">
                    <group string="Step 2 – Review Before Importing">
                        <field name="total_found"   readonly="1" string="Total Rows Found"/>
                        <field name="total_valid"   readonly="1" string="Ready to Import"/>
                        <field name="total_skipped" readonly="1" string="Duplicates (will skip)"/>
                        <field name="total_errors"  readonly="1" string="Rows with Errors"/>
                    </group>
                </group>
                <group attrs="{'invisible': [('state', '!=', 'preview')]}">
                    <field name="preview_html" readonly="1" nolabel="1"/>
                </group>

                <!-- ── STEP 3: DONE ────────────────────────────────────── -->
                <group attrs="{'invisible': [('state', '!=', 'done')]}">
                    <group string="Import Results">
                        <field name="imported_count" readonly="1" string="Records Imported"/>
                        <field name="skipped_count"  readonly="1" string="Records Skipped"/>
                        <field name="error_count"    readonly="1" string="Errors"/>
                    </group>
                    <field name="import_log" readonly="1" nolabel="1"
                           widget="text"
                           style="font-family:monospace;font-size:11px;
                                  background:#f5f7fa;border-radius:4px;padding:10px;"/>
                </group>

                <!-- Hidden state field -->
                <field name="state" invisible="1"/>

                <!-- ── FOOTER BUTTONS ──────────────────────────────────── -->
                <footer>
                    <!-- Step 1 -->
                    <button name="action_analyse" string="Analyse File →"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'upload')]}"
                            icon="fa-search"/>

                    <!-- Step 2 -->
                    <button name="action_import" string="Import Now"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'preview')]}"
                            icon="fa-upload"
                            confirm="This will create compliance records in the database. Continue?"/>
                    <button name="action_back" string="← Back"
                            type="object"
                            attrs="{'invisible': [('state', '!=', 'preview')]}"/>

                    <!-- Step 3 -->
                    <button name="action_open_records" string="View Imported Records"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'done')]}"
                            icon="fa-list"/>
                    <button name="action_back" string="Import Another File"
                            type="object"
                            attrs="{'invisible': [('state', '!=', 'done')]}"/>

                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to launch the wizard -->
    <record id="action_compliance_import_wizard" model="ir.actions.act_window">
        <field name="name">Import from Excel</field>
        <field name="res_model">compliance.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
