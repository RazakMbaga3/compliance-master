<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_compliance_document_tree" model="ir.ui.view">
        <field name="name">compliance.document.tree</field>
        <field name="model">compliance.document</field>
        <field name="arch" type="xml">
            <tree string="Compliance Documents" decoration-bold="is_current">
                <field name="compliance_id"/>
                <field name="version"/>
                <field name="document_name"/>
                <field name="attachment_file" filename="attachment_filename" widget="binary" string="Download"/>
                <field name="attachment_filename" invisible="1"/>
                <field name="uploaded_by"/>
                <field name="upload_date"/>
                <field name="is_current"/>
                <field name="notes"/>
            </tree>
        </field>
    </record>

    <record id="view_compliance_document_form" model="ir.ui.view">
        <field name="name">compliance.document.form</field>
        <field name="model">compliance.document</field>
        <field name="arch" type="xml">
            <form string="Compliance Document">
                <sheet>
                    <group>
                        <field name="compliance_id"/>
                        <field name="version"/>
                        <field name="document_name"/>
                        <field name="attachment_file" filename="attachment_filename" widget="binary"/>
                        <field name="attachment_filename"/>
                        <field name="uploaded_by"/>
                        <field name="upload_date"/>
                        <field name="is_current"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_compliance_document" model="ir.actions.act_window">
        <field name="name">Compliance Documents</field>
        <field name="res_model">compliance.document</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
