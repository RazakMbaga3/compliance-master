<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_compliance_division_tree" model="ir.ui.view">
        <field name="name">compliance.division.tree</field>
        <field name="model">compliance.division</field>
        <field name="arch" type="xml">
            <tree string="Divisions" editable="top">
                <field name="name"/>
                <field name="code"/>
                <field name="record_count" string="Compliances"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_compliance_division_form" model="ir.ui.view">
        <field name="name">compliance.division.form</field>
        <field name="model">compliance.division</field>
        <field name="arch" type="xml">
            <form string="Division">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
