<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════════════════ -->
    <record id="view_compliance_record_form" model="ir.ui.view">
        <field name="name">compliance.record.form</field>
        <field name="model">compliance.record</field>
        <field name="arch" type="xml">
            <form string="Compliance Record">
                <header>
                    <button name="action_set_under_renewal" string="Mark Under Renewal"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', 'in', ['under_renewal', 'inactive'])]}"/>
                    <button name="action_set_active" string="Mark Active"
                            type="object"
                            attrs="{'invisible': [('state', 'in', ['active', 'inactive'])]}"/>
                    <button name="action_set_inactive" string="Set Inactive"
                            type="object"
                            attrs="{'invisible': [('state', '=', 'inactive')]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,due,under_renewal,overdue"/>
                </header>
                <sheet>
                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <field name="document_count" widget="statinfo" string="Documents"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-calendar"
                                attrs="{'invisible': [('days_to_expiry', '=', 0)]}">
                            <field name="days_to_expiry" widget="statinfo" string="Days Left"/>
                        </button>
                    </div>

                    <!-- Title -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Compliance Description"/></h1>
                    </div>

                    <!-- Row 1: Classification + Certificate -->
                    <group>
                        <group string="Classification">
                            <field name="ref"/>
                            <field name="compliance_type"/>
                            <field name="certificate_number"/>
                            <field name="division_id"/>
                            <field name="department_id"/>
                            <field name="agency"/>
                            <field name="location_custodian"/>
                            <field name="vehicle_reg"
                                   attrs="{'invisible': [('compliance_type', '!=', 'fleet')],
                                           'required': [('compliance_type', '=', 'fleet')]}"/>
                        </group>
                        <group string="Frequency &amp; Validity">
                            <field name="frequency"/>
                            <field name="frequency_other"
                                   attrs="{'invisible': [('frequency', '!=', 'other')],
                                           'required':  [('frequency', '=', 'other')]}"/>
                            <field name="due_day_text"
                                   attrs="{'invisible': [('compliance_type', '!=', 'periodic')]}"/>
                            <field name="origin_date"/>
                            <field name="valid_from"/>
                            <field name="expiry_date"/>
                            <field name="renewal_date"/>
                        </group>
                    </group>

                    <!-- Row 2: Responsibility + Notifications -->
                    <group>
                        <group string="Responsibility">
                            <field name="responsible_direct_id"/>
                            <field name="responsible_manager_id"/>
                            <field name="responsible_head_id"/>
                        </group>
                        <group string="Auto Mailer – Days Before Expiry">
                            <field name="notify_direct_days"/>
                            <field name="notify_manager_days"/>
                            <field name="notify_head_days"/>
                        </group>
                    </group>

                    <!-- Tabs -->
                    <notebook>
                        <page string="Documents &amp; Versions" name="documents">
                            <field name="document_ids">
                                <tree editable="bottom" decoration-success="is_current">
                                    <field name="version"/>
                                    <field name="document_name"/>
                                    <field name="attachment_filename" string="File"/>
                                    <field name="uploaded_by"/>
                                    <field name="upload_date"/>
                                    <field name="is_current"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Remarks" name="remarks">
                            <field name="remarks" placeholder="Additional notes, instructions, history…"/>
                        </page>
                        <page string="Notification Log" name="notif_log">
                            <group string="Last notification sent">
                                <field name="notified_direct"  string="Direct (Level 1) Notified"/>
                                <field name="notified_manager" string="Manager (Level 2) Notified"/>
                                <field name="notified_head"    string="Head Notified"/>
                            </group>
                            <p class="text-muted" style="font-size:12px;">
                                Flags reset automatically when a record is marked Active after renewal.
                            </p>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         TREE VIEW
    ══════════════════════════════════════════════════════ -->
    <record id="view_compliance_record_tree" model="ir.ui.view">
        <field name="name">compliance.record.tree</field>
        <field name="model">compliance.record</field>
        <field name="arch" type="xml">
            <tree string="Compliance Records"
                  decoration-danger="state == 'overdue'"
                  decoration-warning="state == 'due'"
                  decoration-info="state == 'under_renewal'"
                  decoration-muted="state == 'inactive'">
                <field name="ref"/>
                <field name="compliance_type" optional="show"/>
                <field name="name"/>
                <field name="certificate_number" optional="hide"/>
                <field name="agency"/>
                <field name="division_id" optional="show"/>
                <field name="department_id"/>
                <field name="vehicle_reg" optional="hide"/>
                <field name="responsible_direct_id"  optional="show"/>
                <field name="responsible_manager_id" optional="hide"/>
                <field name="valid_from"   optional="hide"/>
                <field name="expiry_date"/>
                <field name="days_to_expiry" string="Days Left" optional="show"/>
                <field name="renewal_date" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'overdue'"
                       decoration-warning="state == 'due'"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'under_renewal'"/>
                <field name="document_count" string="Docs"/>
            </tree>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         SEARCH VIEW
    ══════════════════════════════════════════════════════ -->
    <record id="view_compliance_record_search" model="ir.ui.view">
        <field name="name">compliance.record.search</field>
        <field name="model">compliance.record</field>
        <field name="arch" type="xml">
            <search string="Search Compliances">
                <field name="name"/>
                <field name="certificate_number" string="Cert / Licence No."/>
                <field name="agency"/>
                <field name="vehicle_reg" string="Vehicle Reg."/>
                <field name="division_id"/>
                <field name="department_id"/>
                <field name="responsible_direct_id"/>
                <field name="responsible_manager_id"/>
                <field name="responsible_head_id"/>

                <!-- Status filters -->
                <filter string="Active"          name="filter_active"         domain="[('state','=','active')]"/>
                <filter string="Due for Renewal" name="filter_due"            domain="[('state','=','due')]"/>
                <filter string="Under Renewal"   name="filter_under_renewal"  domain="[('state','=','under_renewal')]"/>
                <filter string="Overdue"         name="filter_overdue"        domain="[('state','=','overdue')]"/>
                <filter string="Inactive"        name="filter_inactive"       domain="[('state','=','inactive')]"/>
                <separator/>

                <!-- Type filters -->
                <filter string="Licences / Permits"   name="filter_license"   domain="[('compliance_type','=','license')]"/>
                <filter string="Certificates"         name="filter_cert"      domain="[('compliance_type','=','certificate')]"/>
                <filter string="Fleet / Vehicles"     name="filter_fleet"     domain="[('compliance_type','=','fleet')]"/>
                <filter string="Periodic Submissions" name="filter_periodic"  domain="[('compliance_type','=','periodic')]"/>
                <separator/>

                <!-- Expiry window filters -->
                <filter string="Expiring in 30 Days" name="filter_30"
                        domain="[('expiry_date','&gt;=', context_today().strftime('%Y-%m-%d')),
                                 ('expiry_date','&lt;=', (context_today() + datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <filter string="Expiring in 60 Days" name="filter_60"
                        domain="[('expiry_date','&gt;=', context_today().strftime('%Y-%m-%d')),
                                 ('expiry_date','&lt;=', (context_today() + datetime.timedelta(days=60)).strftime('%Y-%m-%d'))]"/>
                <filter string="Expiring in 90 Days" name="filter_90"
                        domain="[('expiry_date','&gt;=', context_today().strftime('%Y-%m-%d')),
                                 ('expiry_date','&lt;=', (context_today() + datetime.timedelta(days=90)).strftime('%Y-%m-%d'))]"/>
                <separator/>

                <!-- Group by -->
                <group expand="0" string="Group By">
                    <filter string="Division"     name="group_division"    context="{'group_by': 'division_id'}"/>
                    <filter string="Department"   name="group_department"  context="{'group_by': 'department_id'}"/>
                    <filter string="Status"       name="group_status"      context="{'group_by': 'state'}"/>
                    <filter string="Type"         name="group_type"        context="{'group_by': 'compliance_type'}"/>
                    <filter string="Frequency"    name="group_frequency"   context="{'group_by': 'frequency'}"/>
                    <filter string="Agency"       name="group_agency"      context="{'group_by': 'agency'}"/>
                    <filter string="Expiry Month" name="group_expiry"      context="{'group_by': 'expiry_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         PIVOT VIEW
    ══════════════════════════════════════════════════════ -->
    <record id="view_compliance_record_pivot" model="ir.ui.view">
        <field name="name">compliance.record.pivot</field>
        <field name="model">compliance.record</field>
        <field name="arch" type="xml">
            <pivot string="Compliance Summary" display_quantity="true">
                <field name="division_id"   type="row"/>
                <field name="department_id" type="row"/>
                <field name="state"         type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         GRAPH VIEW
    ══════════════════════════════════════════════════════ -->
    <record id="view_compliance_record_graph" model="ir.ui.view">
        <field name="name">compliance.record.graph</field>
        <field name="model">compliance.record</field>
        <field name="arch" type="xml">
            <graph string="Compliance by Division / Department &amp; Status" type="bar" stacked="True">
                <field name="division_id"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         ACTIONS
    ══════════════════════════════════════════════════════ -->
    <record id="action_compliance_record" model="ir.actions.act_window">
        <field name="name">Compliance Records</field>
        <field name="res_model">compliance.record</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="view_compliance_record_search"/>
        <field name="context">{'search_default_group_division': 1}</field>
    </record>

    <record id="action_compliance_overdue" model="ir.actions.act_window">
        <field name="name">Overdue Compliances</field>
        <field name="res_model">compliance.record</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'overdue')]</field>
    </record>

    <record id="action_compliance_due" model="ir.actions.act_window">
        <field name="name">Due for Renewal</field>
        <field name="res_model">compliance.record</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', 'in', ['due', 'under_renewal'])]</field>
    </record>

    <!-- Division list action (config menu) -->
    <record id="action_compliance_division" model="ir.actions.act_window">
        <field name="name">Divisions</field>
        <field name="res_model">compliance.division</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
