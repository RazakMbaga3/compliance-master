<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_compliance_renewal_reminder" model="ir.cron">
        <field name="name">Compliance Master: Send Renewal Reminders</field>
        <field name="model_id" ref="compliance_master.model_compliance_record"/>
        <field name="state">code</field>
        <field name="code">model.send_renewal_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="doall" eval="False"/>
    </record>

    <record id="ir_cron_compliance_recompute_state" model="ir.cron">
        <field name="name">Compliance Master: Recompute Statuses</field>
        <field name="model_id" ref="compliance_master.model_compliance_record"/>
        <field name="state">code</field>
        <field name="code">
records = model.search([('state', 'not in', ['inactive', 'under_renewal']), ('expiry_date', '!=', False)])
records._compute_state()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="doall" eval="False"/>
    </record>
</odoo>
